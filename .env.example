# Copy to .env.local and fill in. Values are in Supabase Dashboard > Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Server-only — never expose to the client. Used by the admin create-user action (Phase 7).
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
